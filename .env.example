# ============================================================================
# Al Ansar Pharmacy API — Environment Variables
#
# Copy this file to .env and fill in your values.
# DO NOT commit the actual .env file — it is in .gitignore.
#
# Three environments: development | staging | production
# ============================================================================

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
LOG_LEVEL=info                # error | warn | info | http | debug

# ── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string.
# development: atlas dev cluster or local docker-compose (mongodb://localhost:27017/pharmacy)
# staging:     atlas staging cluster
# production:  atlas production cluster (M10+ for production workloads)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/pharmacy?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# Minimum 32 random characters each. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_with_different_random_string_min_32_chars
JWT_EXPIRE=15m                # access token TTL  (15m recommended)
# Refresh token TTL is hardcoded to 7 days in Session.model.js

# ── CORS / Client URLs ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Mobile apps do not send an Origin
# header, so they are always allowed regardless of this setting.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CLIENT_URL=http://localhost:3000   # used in password-reset email links

# ── Admin Registration ────────────────────────────────────────────────────────
# Required when creating the first admin via POST /api/auth/register
# with { role: "admin", adminSecret: "..." }
ADMIN_REGISTRATION_SECRET=replace_with_secure_random_string

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Order confirmations, OTP, password reset emails.
# Use Gmail App Password or a transactional provider (SendGrid, Resend, Mailgun).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM_NAME=Al Ansar Pharmacy | صيدلية الأنصار

# ── Cloudinary (Image Storage) ────────────────────────────────────────────────
# Medicine images, prescription photos, avatars, flash sale banners.
# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Stripe (Card Payments) ────────────────────────────────────────────────────
# Use sk_test_... / whsec_test_... in development and staging.
# Mada debit cards are supported natively via Stripe in KSA — no extra config.
STRIPE_SECRET_KEY=sk_test_replace_with_your_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret

# ── Twilio (SMS OTP) ─────────────────────────────────────────────────────────
# Used for phone OTP login. Leave blank to disable SMS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Firebase Cloud Messaging (Push Notifications) ─────────────────────────────
# Paste the entire JSON content of your Firebase service account key as a
# single-line string (or set the path to the JSON file).
# Generate at: Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT=

# ── Nafath (Saudi National Digital ID — elm.sa) ───────────────────────────────
NAFATH_APP_ID=
NAFATH_APP_KEY=
NAFATH_BASE_URL=https://nafath.api.elm.sa
NAFATH_SERVICE_ID=PHARMACY_APP

# ── Biometric Auth ────────────────────────────────────────────────────────────
BIOMETRIC_TOKEN_EXPIRY_DAYS=30

# ── Sentry (Error Tracking) ───────────────────────────────────────────────────
# Leave empty in development. Set in staging and production.
# Install: npm install @sentry/node
# Create a project at sentry.io and copy the DSN here.
SENTRY_DSN=

# ── App Config (returned by GET /api/app/config) ─────────────────────────────
APP_NAME=Al Ansar Pharmacy | صيدلية الأنصار
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=

# Minimum app version — clients below this version will see a force-update prompt
MIN_IOS_VERSION=1.0.0
MIN_ANDROID_VERSION=1.0.0
LATEST_IOS_VERSION=1.0.0
LATEST_ANDROID_VERSION=1.0.0

# ── Support Contact ───────────────────────────────────────────────────────────
SUPPORT_PHONE=
SUPPORT_EMAIL=
WHATSAPP_NUMBER=

# ── Seed Scripts ──────────────────────────────────────────────────────────────
# Used by: node scripts/seed.js
SEED_ADMIN_EMAIL=admin@pharmacy.sa
SEED_ADMIN_PASSWORD=Admin@123456
SEED_PHARMACIST_EMAIL=pharmacist@pharmacy.sa
SEED_PHARMACIST_PASSWORD=Pharmacist@123
SEED_DRIVER_EMAIL=driver@pharmacy.sa
SEED_DRIVER_PASSWORD=Driver@123456

# ── Future / Optional ─────────────────────────────────────────────────────────
# Redis — for caching GET /api/app/home, rate limiter storage, session store.
# Required when scaling to multiple API instances (current in-memory rate
# limiter is per-process and does not share state across instances).
REDIS_URL=

# ZATCA (Saudi e-invoice) — required for businesses registered for VAT
ZATCA_CERT=
ZATCA_CERT_PRIVATE_KEY=
ZATCA_INVOICE_API_URL=

# WhatsApp Business API (Meta Cloud API or Twilio WhatsApp)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
