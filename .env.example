NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# MongoDB
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/pharmacy

# JWT
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=change_this_to_another_long_random_string_min_32_chars
JWT_EXPIRE=15m

# Client URL (for CORS & password reset links)
CLIENT_URL=http://localhost:3000

# Email (Gmail SMTP example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM_NAME=Pharmacy

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin registration secret (for seeding the first admin user)
ADMIN_REGISTRATION_SECRET=change_this_to_a_secure_random_string

# Twilio (optional SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Nafath — Saudi National Digital ID (elm.sa)
NAFATH_APP_ID=
NAFATH_APP_KEY=
NAFATH_BASE_URL=https://nafath.api.elm.sa
NAFATH_SERVICE_ID=PHARMACY_APP

# Biometric token expiry (days, default: 30)
BIOMETRIC_TOKEN_EXPIRY_DAYS=30

# Firebase Cloud Messaging (push notifications)
# Set to the JSON string content of your Firebase service account key
# Generate at: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT=

# App metadata (used in emails + Swagger)
APP_NAME=Pharmacy
