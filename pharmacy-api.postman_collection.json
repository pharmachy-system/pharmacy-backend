{
  "info": {
    "name": "Pharmacy Backend API",
    "description": "Complete API collection for the Pharmacy Backend. Set the `baseUrl` variable to your server URL (default: http://localhost:5000) and use the `accessToken` variable after logging in.",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "orderId", "value": "", "type": "string" },
    { "key": "medicineId", "value": "", "type": "string" },
    { "key": "categoryId", "value": "", "type": "string" },
    { "key": "prescriptionId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) {", "  const body = pm.response.json();", "  pm.collectionVariables.set('accessToken', body.tokens.accessToken);", "  pm.collectionVariables.set('refreshToken', body.tokens.refreshToken);", "}", "pm.test('Status 201', () => pm.response.to.have.status(201));"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"Password123!\",\n  \"phone\": \"0501234567\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) {", "  const body = pm.response.json();", "  pm.collectionVariables.set('accessToken', body.tokens.accessToken);", "  pm.collectionVariables.set('refreshToken', body.tokens.refreshToken);", "}", "pm.test('Status 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"Password123!\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
          }
        },
        {
          "name": "Refresh Token",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) {", "  const body = pm.response.json();", "  pm.collectionVariables.set('accessToken', body.tokens.accessToken);", "  pm.collectionVariables.set('refreshToken', body.tokens.refreshToken);", "}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api", "auth", "refresh"] }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"jane@example.com\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["api", "auth", "forgot-password"] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"password\": \"NewPassword123!\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/reset-password/RESET_TOKEN_HERE", "host": ["{{baseUrl}}"], "path": ["api", "auth", "reset-password", "RESET_TOKEN_HERE"] }
          }
        },
        {
          "name": "Verify Email (OTP)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"jane@example.com\",\n  \"otp\": \"123456\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/verify-email", "host": ["{{baseUrl}}"], "path": ["api", "auth", "verify-email"] }
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"jane@example.com\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/resend-otp", "host": ["{{baseUrl}}"], "path": ["api", "auth", "resend-otp"] }
          }
        },
        {
          "name": "Social Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"provider\": \"google\",\n  \"socialId\": \"google-uid-here\",\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@gmail.com\",\n  \"avatar\": \"https://example.com/photo.jpg\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/social-login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "social-login"] }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Jane Updated\",\n  \"phone\": \"0509876543\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/update-profile", "host": ["{{baseUrl}}"], "path": ["api", "auth", "update-profile"] }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"Password123!\",\n  \"newPassword\": \"NewPassword456!\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/change-password", "host": ["{{baseUrl}}"], "path": ["api", "auth", "change-password"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Medicines",
      "item": [
        {
          "name": "List Medicines",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/medicines?page=1&limit=20", "host": ["{{baseUrl}}"], "path": ["api", "medicines"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "20" }, { "key": "search", "value": "", "disabled": true }, { "key": "category", "value": "", "disabled": true }, { "key": "minPrice", "value": "", "disabled": true }, { "key": "maxPrice", "value": "", "disabled": true }, { "key": "requiresPrescription", "value": "false", "disabled": true }] }
          }
        },
        {
          "name": "Get Medicine",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/medicines/{{medicineId}}", "host": ["{{baseUrl}}"], "path": ["api", "medicines", "{{medicineId}}"] }
          }
        },
        {
          "name": "Create Medicine (Admin)",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) {", "  pm.collectionVariables.set('medicineId', pm.response.json().medicine._id);", "}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "formdata", "formdata": [{ "key": "name", "value": "Paracetamol 500mg", "type": "text" }, { "key": "price", "value": "15", "type": "text" }, { "key": "stock", "value": "200", "type": "text" }, { "key": "category", "value": "{{categoryId}}", "type": "text" }, { "key": "requiresPrescription", "value": "false", "type": "text" }, { "key": "description", "value": "Pain reliever and fever reducer", "type": "text" }] },
            "url": { "raw": "{{baseUrl}}/api/medicines", "host": ["{{baseUrl}}"], "path": ["api", "medicines"] }
          }
        },
        {
          "name": "Update Medicine (Admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"price\": 18,\n  \"stock\": 150\n}" },
            "url": { "raw": "{{baseUrl}}/api/medicines/{{medicineId}}", "host": ["{{baseUrl}}"], "path": ["api", "medicines", "{{medicineId}}"] }
          }
        },
        {
          "name": "Delete Medicine (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/medicines/{{medicineId}}", "host": ["{{baseUrl}}"], "path": ["api", "medicines", "{{medicineId}}"] }
          }
        },
        {
          "name": "Search Medicines",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/medicines?search=paracetamol", "host": ["{{baseUrl}}"], "path": ["api", "medicines"], "query": [{ "key": "search", "value": "paracetamol" }] }
          }
        },
        {
          "name": "Check Drug Interactions",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"medicines\": [\"{{medicineId}}\", \"ANOTHER_MEDICINE_ID\"]\n}" },
            "url": { "raw": "{{baseUrl}}/api/medicines/drug-checker", "host": ["{{baseUrl}}"], "path": ["api", "medicines", "drug-checker"] }
          }
        }
      ]
    },
